    "files": [
      { "path": ".claude-plugin/marketplace.json", "field": "metadata.version" }
    ]
  },
  "plugins": {
    "ua": {
      "files": [
        { "path": "ua/.claude-plugin/plugin.json", "field": "version" },
        { "path": ".claude-plugin/marketplace.json", "field": "plugins.0.version" }
      ]
    },
    "pl": {
      "files": [
        { "path": "pl/.claude-plugin/plugin.json", "field": "version" },
        { "path": ".claude-plugin/marketplace.json", "field": "plugins.1.version" }
      ]
    }
  },
  "audit": {
