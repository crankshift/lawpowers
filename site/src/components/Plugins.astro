---
import PluginCard from './PluginCard.astro'
import { UA_AGENTS, PL_AGENTS, UA_SKILLS_COUNT, PL_SKILLS_COUNT } from '../data'
import type { Translation } from '../locales/en'

interface Props {
  t: Translation
}

const { t } = Astro.props
---

<section class="section" id="jurisdictions">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">{t.plugins.section_eyebrow}</div>
        <h2>{t.plugins.section_title}</h2>
      </div>
      <p>{t.plugins.section_sub}</p>
    </div>
    <div class="plugin-grid">
      <PluginCard
        code="ua"
        t={t}
        agents={UA_AGENTS}
        skillsCount={UA_SKILLS_COUNT}
      />
      <PluginCard
        code="pl"
        t={t}
        agents={PL_AGENTS}
        skillsCount={PL_SKILLS_COUNT}
      />
    </div>
  </div>
</section>

<style>
  .plugin-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto auto auto auto 1fr;
    align-items: stretch;
  }
  @media (max-width: 960px) {
    .plugin-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
  }
</style>
